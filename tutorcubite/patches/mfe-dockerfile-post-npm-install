# Cubite brand: swap the default @openedx/brand for @cubite/brand-openedx
# and install frontend-plugin-framework so the env.config.jsx PLUGIN_SLOTS
# registered by the Python side of this plugin can `import { DIRECT_PLUGIN }`
# at runtime.
RUN npm install '{{ CUBITE_BRAND_ALIAS }}@{{ CUBITE_BRAND_PACKAGE_SPEC }}'
RUN npm install --no-save @openedx/frontend-plugin-framework
